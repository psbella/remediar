/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-MVTN6Sw4i5Kl2lg2S1/S+evZQ3ClwdQGKNnToH573jI=' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://www.google-analytics.com; font-src 'self';

/data/medicamentos.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=7200, stale-while-revalidate=3600
  Access-Control-Allow-Origin: *

/*.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=1800

/style.css
  Cache-Control: public, max-age=86400

/js/*.js
  Cache-Control: public, max-age=86400

/img/*
  Cache-Control: public, max-age=604800, immutable

/favicon.ico
  Cache-Control: public, max-age=604800, immutable

/manifest.json
  Cache-Control: public, max-age=86400
